@startuml UsageLoggingFlow

skinparam shadowing false
skinparam activity {
  BackgroundColor #F5F5F5
  BorderColor #444
}

start

:API route handler\n**finally** block;

:logUsage({\n  ts, ip, ua, route, params,\n  status, durationMs,\n  model, inputTokens, outputTokens, costUsd\n});

partition "logUsage (lib/usage-logger.ts)\ntry/catch — swallows errors" {

  :geolocateIp(ip)\nipwho.is (HTTPS, 3s timeout)\nskips private IPs;

  :appendEntry({ ...entry, geo })\n[lib/usage-storage.ts];

  if (process.env.DATABASE_URL set?) then (yes)
    :INSERT INTO usage_logs (...)\n**Neon Postgres**;
  else (no)
    :fs.appendFile(\n  'data/usage-logs/YYYY-MM-DD.jsonl',\n  JSON.stringify(entry) + '\\n'\n)\n**local disk fallback**;
  endif
}

stop

@enduml
